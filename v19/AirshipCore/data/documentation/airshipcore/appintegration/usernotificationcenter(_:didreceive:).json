{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/AppIntegration\/userNotificationCenter(_:didReceive:)"},"abstract":[{"text":"Processes a user’s response to a notification.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"platforms":["Mac Catalyst"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"userNotificationCenter"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"center"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UNUserNotificationCenter","text":"UNUserNotificationCenter"},{"kind":"text","text":", "},{"kind":"externalParam","text":"didReceive"},{"kind":"text","text":" "},{"kind":"internalParam","text":"response"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UNNotificationResponse","text":"UNNotificationResponse"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"content":[{"type":"paragraph","inlineContent":[{"text":"⚠️ ","type":"text"},{"inlineContent":[{"text":"Deprecated","type":"text"}],"type":"strong"},{"text":". This asynchronous method is deprecated and will be removed in a future release.","type":"text"},{"text":" ","type":"text"},{"text":"It can cause critical application lifecycle issues due to changes in how Apple’s modern User Notification","type":"text"},{"text":" ","type":"text"},{"text":"delegates operate.","type":"text"}]}],"type":"aside","style":"warning","name":"Warning"},{"type":"heading","text":"Lifecycle Issues Explained","level":3,"anchor":"Lifecycle-Issues-Explained"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apple’s modern "},{"type":"codeVoice","code":"async"},{"type":"text","text":" notification delegate methods execute on a "},{"type":"strong","inlineContent":[{"type":"text","text":"background thread"}]},{"type":"text","text":" by default instead of a the main"},{"type":"text","text":" "},{"type":"text","text":"thread. This creates a race condition during app launch:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Main Thread:"}]},{"text":" Proceeds with the standard launch sequence, making the app’s UI active and visible.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Background Thread:"}],"type":"strong"},{"text":" Runs this notification code. By the time it can switch back to the main","type":"text"},{"text":" ","type":"text"},{"text":"thread, the app is often already active.","type":"text"}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This breaks the critical assumption that code for a “direct open” notification runs "},{"type":"emphasis","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" the app is fully"},{"type":"text","text":" "},{"type":"text","text":"interactive. This can lead to incorrect direct open counts."}]},{"type":"heading","text":"Migration","level":3,"anchor":"Migration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To fix this, you must migrate to the synchronous version of this method, which accepts and forwards a "},{"code":"completionHandler","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This guarantees your code runs on the main thread at the correct point in the lifecycle, before the app becomes active."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"center: The notification center that delivered the notification."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"response: The user’s response to the notification."}]}]}],"type":"unorderedList"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"userNotificationCenter(_:didReceive:withCompletionHandler:)","type":"codeVoice"}]}],"type":"aside","style":"note","name":"See Also"}],"kind":"content"}],"deprecationSummary":[{"inlineContent":[{"text":"Use the synchronous version with a completionHandler to avoid lifecycle issues.","type":"text"}],"type":"paragraph"}],"hierarchy":{"paths":[["doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore","doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/AppIntegration"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/airshipcore\/appintegration\/usernotificationcenter(_:didreceive:)"]}],"metadata":{"title":"userNotificationCenter(_:didReceive:)","modules":[{"name":"AirshipCore"}],"role":"symbol","roleHeading":"Type Method","platforms":[{"message":"Use the synchronous version with a completionHandler to avoid lifecycle issues.","unavailable":false,"beta":false,"deprecated":true}],"externalID":"s:11AirshipCore14AppIntegrationC22userNotificationCenter_10didReceiveySo06UNUserfG0C_So22UNNotificationResponseCtYaFZ","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"userNotificationCenter","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"c:objc(cs)UNUserNotificationCenter","text":"UNUserNotificationCenter","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"didReceive","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)UNNotificationResponse","text":"UNNotificationResponse","kind":"t