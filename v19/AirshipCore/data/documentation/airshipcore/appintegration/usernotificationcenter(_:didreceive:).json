 thread","type":"text"}]},{"type":"text","text":" by default instead of a the main"},{"type":"text","text":" "},{"type":"text","text":"thread. This creates a race condition during app launch:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Main Thread:"}]},{"type":"text","text":" Proceeds with the standard launch sequence, making the app’s UI active and visible."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Background Thread:","type":"text"}],"type":"strong"},{"text":" Runs this notification code. By the time it can switch back to the main","type":"text"},{"text":" ","type":"text"},{"text":"thread, the app is often already active.","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"This breaks the critical assumption that code for a “direct open” notification runs "},{"type":"emphasis","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" the app is fully"},{"type":"text","text":" "},{"type":"text","text":"interactive. This can lead to incorrect direct open counts."}],"type":"paragraph"},{"text":"Migration","type":"heading","level":3,"anchor":"Migration"},{"inlineContent":[{"text":"To fix this, you must migrate to the synchronous version of this method, which accepts and forwards a ","type":"text"},{"code":"completionHandler","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"This guarantees your code runs on the main thread at the correct point in the lifecycle, before the app becomes active.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"center: The notification center that delivered the notification.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"response: The user’s response to the notification.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"content":[{"inlineContent