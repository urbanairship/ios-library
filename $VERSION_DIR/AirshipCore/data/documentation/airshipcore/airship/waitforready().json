},{"type":"codeVoice","code":"true"},{"text":"), this method returns immediately","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If Airship is not yet initialized, this method suspends until initialization completes","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The method will not throw or fail - it simply waits for the ready state"}],"type":"paragraph"}]}],"type":"unorderedList"},{"content":[{"inlineContent":[{"text":"This method must be called from the main thread.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"text":"This method assumes ","type":"text"},{"type":"codeVoice","code":"Airship.takeOff"},{"text":" has been called. If ","type":"text"},{"type":"codeVoice","code":"takeOff"},{"text":" ","type":"text"},{"text":"is never called, this method will suspend indefinitely.","type":"text"}]}],"style":"important","name":"Important","type":"aside"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:11AirshipCore0A0C12waitForReadyyyYaFZ","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitForReady","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"}],"symbolKind":"method","roleHeading":"Type Method","title":"waitForReady()","extendedModule":"AirshipCore","role":"symbol","modules":[{"name":"AirshipCore"}]},"references":{"doc://com.urbanairship.AirshipCore/documentation/AirshipCore/Airship/waitForReady()":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitForReady","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"}],"role":"symbol","url":"\/documentation\/airshipcore\/airship\/waitforready()","identifier":"doc:\