{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Waits for Airship to be ready using async\/await."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/Airship\/waitForReady()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitForReady"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This method provides a modern async\/await interface for waiting until Airship","type":"text"},{"text":" ","type":"text"},{"text":"has finished initializing. It’s particularly useful when you need to ensure","type":"text"},{"text":" ","type":"text"},{"text":"Airship is ready before performing operations that depend on it.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Usage","text":"Usage","type":"heading"},{"syntax":"swift","code":["\/\/ Wait for Airship to be ready","await Airship.waitForReady()","","\/\/ Now safe to use Airship components","Airship.push.enableUserNotifications()"],"type":"codeListing"},{"level":2,"anchor":"Behavior","text":"Behavior","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"If Airship is already initialized ("},{"code":"isFlying","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":"), this method returns immediately"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If Airship is not yet initialized, this method suspends until initialization completes"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The method will not throw or fail - it simply waits for the ready state","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This method must be called from the main thread.","type":"text"}]}],"type":"aside","name":"Note"},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"This method assumes ","type":"text"},{"type":"codeVoice","code":"Airship.takeOff"},{"text":" has been called. If ","type":"text"},{"type":"codeVoice","code":"takeOff"},{"text":" ","type":"text"},{"text":"is never called, this method will suspend indefinitely.","type":"text"}]}],"type":"aside","name":"Important"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/airshipcore\/airship\/waitforready()"]}],"sections":[],"metadata":{"symbolKind":"method","modules":[{"name":"AirshipCore"}],"title":"waitForReady()","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitForReady"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"}],"externalID":"s:11AirshipCore0A0C12waitForReadyyyYaFZ","role":"symbol","extendedModule":"AirshipCore","roleHeading":"Type Method"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore","doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/Airship"]]},"references":{"doc://com.urbanairship.AirshipCore/documentation/AirshipCore":{"type":"topic","title":"AirshipCore","kind":"symbol","identifier":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore","abstract":[],"url":"\/documentation\/airshipcore","role":"collection"},"doc://com.urbanairship.AirshipCore/documentation/AirshipCore/Airship/waitForReady()":{"identifier":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/Airs