{"abstract":[{"text":"Creates a set of categories from the specified ","type":"text"},{"code":".plist","type":"codeVoice"},{"text":" file.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories\/createCategories(fromFile:)"},"metadata":{"role":"symbol","modules":[{"name":"AirshipCore"}],"title":"createCategories(fromFile:)","externalID":"s:11AirshipCore22NotificationCategoriesC06createD08fromFileShySo22UNNotificationCategoryCGSS_tFZ","roleHeading":"Type Method","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"createCategories","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fromFile","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"Set","kind":"typeIdentifier","preciseIdentifier":"s:Sh"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:objc(cs)UNNotificationCategory","kind":"typeIdentifier","text":"UNNotificationCategory"},{"kind":"text","text":">"}],"symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore","doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"createCategories"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fromFile"},{"kind":"text","text":" "},{"kind":"internalParam","text":"path"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sh","text":"Set"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UNNotificationCategory","text":"UNNotificationCategory"},{"kind":"text","text":">"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"name":"path","content":[{"inlineContent":[{"type":"text","text":"The path of the "},{"type":"codeVoice","code":"plist"},{"type":"text","text":" file"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A set of categories","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Categories are defined in a plist dictionary with the category ID"},{"type":"text","text":" "},{"type":"text","text":"followed by an array of user notification action definitions. The"},{"type":"text","text":" "},{"type":"text","text":"action definitions use the same keys as the properties on the action,"},{"type":"text","text":" "},{"type":"text","text":"with the exception of “foreground” mapping to either UIUserNotificationActivationModeForeground"},{"type":"text","text":" "},{"type":"text","text":"or UIUserNotificationActivationModeBackground. The required action definition"},{"type":"text","text":" "},{"type":"text","text":"title can be defined with either the “title” or “title_resource” key, where"},{"type":"text","text":" "},{"type":"text","text":"the latter takes precedence. If “title_resource” does not exist, the action"},{"type":"text","text":" "},{"type":"text","text":"definition title will fall back to the value of “title”. If the required action"},{"type":"text","text":" "},{"type":"text","text":"definition title is not defined, the category will not be created."}]},{"type":"paragraph","inlineContent":[{"text":"Example:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"{"},{"type":"text","text":" "},{"type":"text","text":"“category_id” : ["},{"type":"text","text":" "},{"type":"text","text":"{"},{"type":"text","text":" "},{"type":"text","text":"“identifier” : “action ID”,"},{"type":"text","text":" "},{"type":"text","text":"“title_resource” : “action title resource”,"},{"type":"text","text":" "},{"type":"text","text":"“title” : “action title”,"},{"type":"text","text":" "},{"type":"text","text":"“foreground” : true,"},{"type":"text","text":" "},{"type":"text","text":"“authenticationRequired” : false,"},{"type":"text","text":" "},{"type":"text","text":"“destructive” : false"},{"type":"text","text":" "},{"type":"text","text":"}]"},{"type":"text","text":" "},{"type":"text","text":"}"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/airshipcore\/notificationcategories\/createcategories(fromfile:)"]}],"references":{"doc://com.urbanairship.AirshipCore/documentation/AirshipCore/NotificationCategories":{"url":"\/documentation\/airshipcore\/notificationcategories","type":"topic","title":"NotificationCategories","kind":"symbol","identifier":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories","abstract":[{"type":"text","text":"Utility methods to create categories from plist files or dictionaries."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"NotificationCategories"}],"navigatorTitle":[{"kind":"identifier","text":"NotificationCategories"}],"role":"symbol"},"doc://com.urbanairship.AirshipCore/documentation/AirshipCore/NotificationCategories/createCategories(fromFile:)":{"identifier":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories\/createCategories(fromFile:)","title":"createCategories(fromFile:)","url":"\/documentation\/airshipcore\/notificationcategories\/createcategories(fromfile:)","abstract":[{"text":"Creates a set of cat