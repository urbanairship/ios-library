{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories\/createCategories(fromFile:)","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore","doc:\/\/com.urbanairship.AirshipCore\/documentation\/AirshipCore\/NotificationCategories"]]},"abstract":[{"type":"text","text":"Creates a set of categories from the specified "},{"type":"codeVoice","code":".plist"},{"type":"text","text":" file."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"createCategories"},{"kind":"text","text":"("},{"text":"fromFile","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"path","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"Set","kind":"typeIdentifier","preciseIdentifier":"s:Sh"},{"text":"<","kind":"text"},{"text":"UNNotificationCategory","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)UNNotificationCategory"},{"text":">","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The path of the "},{"code":"plist","type":"codeVoice"},{"type":"text","text":" file"}]}],"name":"path"}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"type":"text","text":"A set of categories"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Categories are defined in a plist dictionary with the category ID"},{"type":"text","text":" "},{"type":"text","text":"followed by an array of user notification action definitions. The"},{"type":"text","text":" "},{"type":"text","text":"action definitions use the same keys as the properties on the action,"},{"type":"text","text":" "},{"type":"text","text":"with the exception of “foreground” mapping to either UIUserNotificationActivationModeForeground"},{"type":"text","text":" "},{"type":"text","text":"or UIUserNotificationActivationModeBackground. The required action definition"},{"type":"text","text":" "},{"type":"text","text":"title can be defined with either the “title” or “title_resource” key, where"},{"type":"text","text":" "},{"type":"text","text":"the latter takes precedence. If “title_resource” does not exist, the action"},{"type":"text","text":" "},{"type":"text","text":"definition title will fall back to the value of “title”. If the required action"},{"type":"text","text":" "},{"type":"text","text":"definition title is not defined, the category will not be created."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"type":"paragraph","inlineContent":[{"text":"{","type":"text"},{"text":" ","type":"text"},{"text":"“category_id” : [","type":"text"},{"text":" ","type":"text"},{"text":"{","type":"text"},{"text":" ","type":"text"},{"text":"“identifier” : “action ID”,","type":"text"},{"text":" ","type":"text"},{"text":"“title_resource” : “action title resource”,","type":"text"},{"text":" ","type":"text"},{"text":"“title” : “action title”,","type":"text"},{"text":" ","type":"text"},{"text":"“foreground” : true,","type":"text"},{"text":" ","type":"text"},{"text":"“authenticationRequired” : false,","type":"text"},{"text":" ","type":"text"},{"text":"“destructive” : false","type":"text"},{"text":" ","type":"text"},{"text":"}]","type":"text"},{"text":" ","type":"text"},{"text":"}","type":"text"}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/airshipcore\/notificationcategories\/createcategories(fromfile: